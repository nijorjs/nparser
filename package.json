{
  "name": "@nijor/nparser",
  "version": "1.0.0",
  "description": "A custom html-parser for Nijor",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nijorjs/nparser.git"
  },
  "license": "MIT",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "nparser",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
